<Page x:Class="WpfDiDay.Views.Home.HomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WpfDiDay.Views.Home"
      mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="900"
      Title="HomePage" Background="#F4F7F6">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" Padding="40,30" 
                BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
            <StackPanel>
                <TextBlock Text="BẢNG ĐIỀU KHIỂN" FontSize="13" FontWeight="Bold" 
                           Foreground="#64748B" Margin="0,0,0,5"/>

                <TextBlock x:Name="txtWelcome" Text="{Binding WelcomeText}" 
                           FontSize="32" FontWeight="Bold" Foreground="#0F172A"/>

                <TextBlock Text="Hôm nay bạn muốn làm gì?" FontSize="15" 
                           Foreground="#64748B" Margin="0,5,0,0"/>
            </StackPanel>
        </Border>
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Thêm món ăn" FontFamily="Cambria" BorderThickness="5" Background="DarkSeaGreen" Margin="5" FontSize="20" Command="{Binding OpenAddFoodCommand}"/>
            <Button Content="Xóa món ăn" FontFamily="Cambria" Background="LightCoral" Margin="5" BorderThickness="5" FontSize="20"  Command="{Binding RemoveFoodCommand}"/>
            <Button Content="Sửa món ăn" FontFamily="Cambria" Background="LightSkyBlue" Margin="5" BorderThickness="5"  FontSize="20" Command="{Binding OpenEditFoodCommand}"/>
        </StackPanel>
        <Grid Grid.Row="2" Margin="40">
            <DataGrid ItemsSource="{Binding Foods}" 
                AutoGenerateColumns="False"
                CanUserAddRows="False"
                CanUserDeleteRows="False"
                SelectionMode="Single"
                SelectionChanged="FoodAnalysis_SelectionChanged">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Tên món ăn" 
                            FontFamily="Cambria" 
                            Binding="{Binding FoodName}" 
                            Width="3*" 
                            IsReadOnly="True"/>
                    <DataGridTextColumn Header="Thời gian ăn" 
                            Binding="{Binding FoodEatingTime, StringFormat='dd/MM/yyyy'}" 
                            Width="5*" 
                            FontFamily="Cambria" 
                            IsReadOnly="True"/>
                    <DataGridTextColumn Header="Lượng Calories"
                            Binding="{Binding FoodCalories, StringFormat='{}{0} cal'}" 
                            Width="*" 
                            FontFamily="Cambria" 
                            IsReadOnly="True"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
</Page>