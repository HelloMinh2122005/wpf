<Page x:Class="WpfDiDay.Views.Home.HomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WpfDiDay.Views.Home"
      mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="900"
      Title="HomePage" Background="#F4F7F6">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" Padding="40,30" 
                BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="BẢNG ĐIỀU KHIỂN" FontSize="13" FontWeight="Bold" 
                                Foreground="#64748B" Margin="0,0,0,5"/>

                    <TextBlock x:Name="txtWelcome" Text="{Binding WelcomeText}" 
                                FontSize="32" FontWeight="Bold" Foreground="#0F172A"/>

                    <TextBlock Text="Hôm nay bạn muốn làm gì?" FontSize="15" 
                                Foreground="#64748B" Margin="0,5,0,0"/>
                </StackPanel>
                <WrapPanel Grid.Column="1" HorizontalAlignment="Right" ItemWidth="250" ItemHeight="150">
                    <Border Background="#FEF2F2" BorderBrush="#FECACA" BorderThickness="1" 
                            CornerRadius="12" Margin="0,0,20,20" Padding="20" Cursor="Hand"
                            MouseLeftButtonDown="Logout_Click">
                        <StackPanel>
                            <TextBlock Text="🚪" FontSize="30" Margin="0,0,0,10"/>
                            <TextBlock Text="Đăng xuất" FontSize="18" FontWeight="SemiBold" Foreground="#DC2626"/>
                        </StackPanel>
                    </Border>
                </WrapPanel>
            </Grid>    
                
        </Border>

        
        <StackPanel Grid.Row="1" Orientation="Vertical">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="THÊM" Background="Transparent" BorderBrush="Transparent" BorderThickness="0" 
                        FontSize="36" FontWeight="Bold" Margin="0,0,15,0" 
                        Command="{Binding AddFoodCommand}" CommandParameter="{Binding}"/>
                <Button Content="CHỈNH SỬA" Foreground="Green"  Background="Transparent" BorderBrush="Transparent" BorderThickness="0"
                        FontSize="36" FontWeight="Bold" Margin="0,0,15,0" 
                        Command="{Binding FoodDetailCommand}" CommandParameter="{Binding}"/>
                <Button Content="XÓA" Background="Transparent" BorderBrush="Transparent" BorderThickness="0" 
                        FontSize="36" FontWeight="Bold" Margin="0,0,15,0" 
                        Command="{Binding RemoveFoodCommand}" CommandParameter="{Binding}"/>
            </StackPanel>
            <Border Margin="10">
                <StackPanel>
                    <!-- DataGrid -->
                    <TextBlock Text="FoodLog" FontSize="34"  Margin="0,0,0,10"/>

                    <DataGrid x:Name="DataGrid_FoodLogs"
                              ItemsSource="{Binding FoodLogs}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Món ăn" Binding="{Binding FoodName}" Width="2*"/>
                            <DataGridTextColumn Header="Thời điểm ăn" Binding="{Binding FoodName}" Width="2*"/>
                            <DataGridTextColumn Header="Calories" Binding="{Binding Calories}" Width="2*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>
        </StackPanel>    
            
    </Grid>
</Page>