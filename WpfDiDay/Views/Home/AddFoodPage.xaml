<Page x:Class="WpfDiDay.Views.Home.AddFoodPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WpfDiDay.Views.Home"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="AddFoodPage">

    <Grid>
        <Border Width="Auto" CornerRadius="12" Background="White"
                BorderBrush="#E6EEF3" BorderThickness="1"
                Padding="24 ">
            <StackPanel>
                <!-- Header -->
                <DockPanel Margin="0,0,0,12">
                    <TextBlock DockPanel.Dock="Left" 
                               Text="Ăn nữa hả ..." FontSize="28" FontWeight="Bold" Foreground="#0F766E" />
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="btnBack" Content="BACK" Width="88" Height="36" 
                                Background="Transparent" BorderBrush="#E2E8F0" Foreground="#334155" 
                                Command="{Binding BackHomeCommand}"/>
                        <Button x:Name="btnSave" Content="SAVE" Width="100" Height="36" 
                                Background="#0EA5A4" Foreground="White" 
                                Command="{Binding SaveFoodCommand}"/>
                    </StackPanel>
                </DockPanel>

                <Separator Margin="0,0,0,8" />

                <!-- Form -->
                <StackPanel>
                    <!-- Food name -->
                    <StackPanel>
                        <TextBlock Text="Tên món ăn" FontSize="14" Foreground="#475569" Margin="0,0,0,4"/>
                        <TextBox x:Name="txtFoodName" Height="36" FontSize="14" Padding="8" Text ="{Binding Foodname, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <!-- Date / When eaten -->
                    <StackPanel>
                        <TextBlock Text="Ngày ăn (DD/MM/YY)" FontSize="14" Foreground="#475569" Margin="0,0,0,4"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBox x:Name="txtDay" Height="36" Width="120" Text ="{Binding Day, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBox x:Name="txtMonth" Height="36" Width="120" Text ="{Binding Month, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="8,0,0,0"/>
                            <TextBox x:Name="txtYear" Height="36" Width="120" Text ="{Binding Year, UpdateSourceTrigger=PropertyChanged}" 
                                     Margin="8,0,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Calories -->
                    <StackPanel>
                        <TextBlock Text="Calories (cal)" FontSize="14" Foreground="#475569" Margin="0,0,0,4"/>
                        <TextBox x:Name="txtCalories" Height="36" FontSize="14" Padding="8"/>
                    </StackPanel>

                    <!-- Optional helper text -->
                    <TextBlock Text="Ăn uống lành mạnh vì một tương lại khỏe mạnh"
                               FontSize="12" Foreground="#94A3B8" TextWrapping="Wrap" Margin="0,6,0,0"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Page>
