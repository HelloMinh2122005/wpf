<Page x:Class="WpfDiDay.Views.Home.FoodDetail"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WpfDiDay.Views.Home"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="FoodDetail">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header Section -->
        <Border Grid.Row="0" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="40,30">
            <StackPanel>
                <TextBlock Text="THÊM THÔNG TIN THỨC ĂN" 
                        FontFamily="Segoe UI" 
                        FontSize="28" 
                        FontWeight="Bold" 
                        Foreground="#1F2937"
                        Margin="0,0,0,10"/>
                <TextBlock Text="Nhập chi tiết thông tin về món ăn của bạn" 
                        FontFamily="Segoe UI" 
                        FontSize="14" 
                        Foreground="#6B7280"/>
            </StackPanel>
        </Border>

        <!-- Form Section -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="60,40" MaxWidth="500">
                <!-- Tên Món Ăn -->
                <TextBlock Text="Tên Món Ăn" 
                        FontFamily="Segoe UI" 
                        FontSize="16" 
                        FontWeight="SemiBold" 
                        Foreground="#1F2937"
                        Margin="0,0,0,8"/>
                <Border BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="6" Background="White" Padding="0">
                    <TextBox x:Name="FoodNameTextBox"
                          Text="{Binding FoodName, UpdateSourceTrigger=PropertyChanged}"
                          Height="44" 
                          Padding="14,12" 
                          BorderThickness="0" 
                          Background="Transparent" 
                          FontSize="14" 
                          Foreground="#1F2937"
                          FontFamily="Segoe UI"/>
                </Border>
                <TextBlock Text="Nhập tên món ăn" FontSize="11" Foreground="#9CA3AF" Margin="0,4,0,20"/>

                <!-- Thời gian ăn -->
                <TextBlock Text="Thời Gian Ăn (dd/MM/yyyy)" 
                        FontFamily="Segoe UI" 
                        FontSize="16" 
                        FontWeight="SemiBold" 
                        Foreground="#1F2937"
                        Margin="0,0,0,8"/>
                <Border BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="6" Background="White" Padding="0">
                    <TextBox x:Name="FoodEatingTimeTextBox"
                          Text="{Binding FoodEatingTime, StringFormat='dd/MM/yyyy', UpdateSourceTrigger=PropertyChanged}"
                          Height="44" 
                          Padding="14,12" 
                          BorderThickness="0" 
                          Background="Transparent" 
                          FontSize="14" 
                          Foreground="#1F2937"
                          FontFamily="Segoe UI"/>
                </Border>
                <TextBlock Text="Ví dụ: 15/03/2026" FontSize="11" Foreground="#9CA3AF" Margin="0,4,0,20"/>

                <!-- Lượng Calories -->
                <TextBlock Text="Lượng Calories (cal)" 
                        FontFamily="Segoe UI" 
                        FontSize="16" 
                        FontWeight="SemiBold" 
                        Foreground="#1F2937"
                        Margin="0,0,0,8"/>
                <Border BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="6" Background="White" Padding="0">
                    <TextBox x:Name="FoodCaloriesTextBox"
                          Text="{Binding FoodCalories, UpdateSourceTrigger=PropertyChanged}"
                          Height="44" 
                          Padding="14,12" 
                          BorderThickness="0" 
                          Background="Transparent" 
                          FontSize="14" 
                          Foreground="#1F2937"
                          FontFamily="Segoe UI"/>
                </Border>
                <TextBlock Text="Nhập số lượng calorie" FontSize="11" Foreground="#9CA3AF" Margin="0,4,0,0"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Button Section -->
        <Border Grid.Row="2" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0" Padding="40,20">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Hủy" 
                     FontFamily="Segoe UI" 
                     FontSize="14" 
                     FontWeight="SemiBold"
                     Foreground="#1F2937"
                     Background="#F3F4F6" 
                     BorderBrush="#D1D5DB"
                     BorderThickness="1"
                     Padding="20,12" 
                     MinWidth="100"
                     Cursor="Hand"
                     Command="{Binding BackCommand}">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" 
                                             BorderBrush="{TemplateBinding BorderBrush}" 
                                             BorderThickness="{TemplateBinding BorderThickness}"
                                             CornerRadius="6"
                                             Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#E5E7EB"/>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter Property="Background" Value="#D1D5DB"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>

                <Button Content="💾 Lưu Thay Đổi" 
                     FontFamily="Segoe UI" 
                     FontSize="14" 
                     FontWeight="SemiBold"
                     Foreground="White"
                     Background="#10B981" 
                     BorderThickness="0"
                     Padding="20,12" 
                     MinWidth="150"
                     Cursor="Hand"
                     Command="{Binding SaveFoodCommand}">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" 
                                             CornerRadius="6"
                                             Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#059669"/>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter Property="Background" Value="#047857"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Page>
